{
  "name": "Lictom",
  "version": "1.0.0",
  "manifest_version": 2,
  "description": "Controle de Saldos de Pregão - 23ª Esqd C Sl",
  "content_security_policy": "script-src 'self' 'unsafe-eval'; object-src 'self'",
  "permissions": [
    "storage",
    "alarms",
    "https://sag.eb.mil.br/*",
    "https://*.github.io/*"
  ],
  "background": {
    "scripts": ["background/service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://sag.eb.mil.br/*"],
      "js": ["content/inject.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
